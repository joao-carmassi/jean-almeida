---
import type { FAQPage, Physician, WithContext } from 'schema-dts';

import { AboutSection } from '@/components/about6';
import { ContactSection } from '@/components/contact6';
import { CtaSection } from '@/components/cta20';
import { FaqSection } from '@/components/faq4';
import { HeroSection } from '@/components/hero4';
import { ProcessSection } from '@/components/process2';
import { ServicesSection } from '@/components/case-studies6';
import { StatsSection } from '@/components/stats6';
import { TestimonialSection } from '@/components/testimonial18';
import Layout from '@/layouts/layout.astro';
import { getBasePath } from '@/utils/env';
import serialize from 'serialize-javascript';
import getPictureImage from '@/utils/get-picture-image';
import img1 from '@/assets/hero.jpeg';

import img2 from '@/assets/clinica/Consolação.jpg';
import img3 from '@/assets/clinica/LCM_1643.jpg';
import img4 from '@/assets/clinica/LCM_1631.jpg';
import img5 from '@/assets/clinica/LCM_1642.jpg';
import img6 from '@/assets/clinica/LCM_1647.jpg';
import img7 from '@/assets/clinica/LCM_1576.jpg';

import img8 from '@/assets/clinica/LCM_1642.jpg';
import img9 from '@/assets/clinica/LCM_1637.jpg';
import img10 from '@/assets/clinica/LCM_1640.jpg';
import img11 from '@/assets/clinica/LCM_1636.jpg';
import img12 from '@/assets/clinica/LCM_1643.jpg';
import img13 from '@/assets/clinica/LCM_1644.jpg';
import img14 from '@/assets/clinica/LCM_1638.jpg';

import img15 from '@/assets/clinica/LCM_1565.jpg';
import img16 from '@/assets/clinica/LCM_1563.jpg';
import img17 from '@/assets/clinica/LCM_1559.jpg';
import img18 from '@/assets/clinica/LCM_1578.jpg';

const siteUrl = getBasePath();

const medicoBusiness: WithContext<Physician> = {
  '@context': 'https://schema.org',
  '@type': 'Physician',
  name: 'Dr. Jean Almeida — Psiquiatra em São Paulo',
  description:
    'Psiquiatra humanizado na Av. Paulista, São Paulo. Tratamento para depressão, ansiedade, TDAH, burnout e mais. CRM 127.207.',
  url: siteUrl,
  telephone: '+5511913259328',
  email: 'drjean.psiquiatria@gmail.com',
  medicalSpecialty: 'Psychiatric',
  priceRange: 'R$$$',
  currenciesAccepted: 'BRL',
  paymentAccepted: 'Cartão de crédito, débito, Pix',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Av. Paulista, 2494 — Conjunto 94',
    addressLocality: 'São Paulo',
    addressRegion: 'SP',
    postalCode: '01310-300',
    addressCountry: 'BR',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: -23.5614,
    longitude: -46.6565,
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '09:00',
      closes: '19:00',
    },
  ],
  areaServed: {
    '@type': 'City',
    name: 'São Paulo',
  },
};

const faqSchema: WithContext<FAQPage> = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Qual a diferença entre psiquiatra e psicólogo?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'O psiquiatra é médico especializado em saúde mental — pode fazer diagnósticos, prescrever medicamentos e indicar exames. O psicólogo realiza psicoterapia, mas não prescreve medicação.',
      },
    },
    {
      '@type': 'Question',
      name: 'Preciso de encaminhamento médico para consultar?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Não. Você pode agendar sua consulta diretamente, sem necessidade de encaminhamento. Basta entrar em contato pelo WhatsApp ou formulário.',
      },
    },
    {
      '@type': 'Question',
      name: 'O Dr. Jean atende pelo convênio?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'As consultas são realizadas de forma particular. Aceitamos cartões de crédito e débito. Muitos planos de saúde oferecem reembolso — consulte o seu.',
      },
    },
    {
      '@type': 'Question',
      name: 'É possível fazer consulta online?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sim, oferecemos consultas por telemedicina para pacientes que não podem comparecer presencialmente.',
      },
    },
    {
      '@type': 'Question',
      name: 'Como sei se preciso de um psiquiatra?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Se você está sofrendo — seja com tristeza, ansiedade, insônia, mudanças de humor ou dificuldades emocionais — já é motivo suficiente para buscar ajuda. Não espere a situação piorar.',
      },
    },
    {
      '@type': 'Question',
      name: 'O consultório fica em que bairro de São Paulo?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'O consultório está localizado na Av. Paulista, 2494 — conjunto 94, no bairro Bela Vista, São Paulo. Fácil acesso pelo metrô (estação Consolação ou Trianon-MASP).',
      },
    },
    {
      '@type': 'Question',
      name: 'O atendimento é feito em outro idioma além do português?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sim. O Dr. Jean Almeida atende também em Espanhol.',
      },
    },
  ],
};

const heroImages = await Promise.all([
  getPictureImage({ src: img1, width: 574, height: 574 }),
]);

const aboutImages = await Promise.all([
  getPictureImage({ src: img2, width: 350, height: 500 }),
  getPictureImage({ src: img3, width: 350, height: 318 }),
  getPictureImage({ src: img4, width: 350, height: 500 }),
  getPictureImage({ src: img5, width: 350, height: 380 }),
  getPictureImage({ src: img6, width: 350, height: 437 }),
  getPictureImage({ src: img7, width: 350, height: 388 }),
]);

const servicesImages = await Promise.all([
  getPictureImage({ src: img8, width: 340, height: 432 }),
  getPictureImage({ src: img9, width: 340, height: 432 }),
  getPictureImage({ src: img10, width: 340, height: 432 }),
  getPictureImage({ src: img11, width: 340, height: 432 }),
  getPictureImage({ src: img12, width: 340, height: 432 }),
  getPictureImage({ src: img13, width: 340, height: 432 }),
  getPictureImage({ src: img14, width: 340, height: 432 }),
]);

const processImages = await Promise.all([
  getPictureImage({ src: img15, width: 694, height: 358 }),
  getPictureImage({ src: img16, width: 694, height: 358 }),
  getPictureImage({ src: img17, width: 694, height: 358 }),
  getPictureImage({ src: img18, width: 694, height: 358 }),
]);
---

<Layout
  title='Psiquiatra em São Paulo — Dr. Jean Almeida | CRM 127.207'
  description='Consulte com o Dr. Jean Almeida, psiquiatra humanizado na Av. Paulista, São Paulo. Tratamento para depressão, ansiedade, TDAH, burnout e mais. Agende agora.'
  canonical={siteUrl}
  openGraph={{
    basic: {
      title: 'Psiquiatra em São Paulo — Dr. Jean Almeida | CRM 127.207',
      type: 'website',
      image: `${siteUrl}/og-image.jpg`,
      url: siteUrl,
    },
    optional: {
      description:
        'Consulte com o Dr. Jean Almeida, psiquiatra humanizado na Av. Paulista, São Paulo. Tratamento para depressão, ansiedade, TDAH, burnout e mais. Agende agora.',
      siteName: 'Dr. Jean Almeida — Psiquiatra em São Paulo',
      locale: 'pt_BR',
    },
    image: {
      alt: 'Dr. Jean Almeida — Psiquiatra em São Paulo',
    },
  }}
  twitter={{
    card: 'summary_large_image',
    title: 'Psiquiatra em São Paulo — Dr. Jean Almeida | CRM 127.207',
    description:
      'Consulte com o Dr. Jean Almeida, psiquiatra humanizado na Av. Paulista, São Paulo. Tratamento para depressão, ansiedade, TDAH, burnout e mais.',
    image: `${siteUrl}/og-image.jpg`,
    imageAlt: 'Dr. Jean Almeida — Psiquiatra em São Paulo',
  }}
>
  <!-- JSON-LD Schema: MedicalBusiness -->
  <script
    is:inline
    type='application/ld+json'
    set:html={serialize(medicoBusiness)}
    slot='head'
  />
  <!-- JSON-LD Schema: FAQPage -->
  <script
    is:inline
    type='application/ld+json'
    set:html={serialize(faqSchema)}
    slot='head'
  />
  <main>
    <HeroSection images={heroImages} client:load />
    <AboutSection images={aboutImages} />
    <StatsSection />
    <ServicesSection images={servicesImages} client:visible />
    <ProcessSection images={processImages} client:visible />
    <TestimonialSection client:visible />
    <FaqSection client:visible />
    <CtaSection />
    <ContactSection />
  </main>
</Layout>
